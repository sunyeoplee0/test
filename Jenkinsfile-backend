pipeline {
    agent any

    // 젠킨스 Tools에 'jdk17'이 등록되어 있어야 합니다.
    tools {
        jdk 'jdk17'
    }

    environment {
        DOCKER_IMAGE = "sunyeoplee/backend-app"
        NAMESPACE = "lee"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Backend Build') {
            steps {
                // 백엔드 소스 코드가 있는 폴더명으로 수정하세요 (예: backend)
                dir('backend') {
                    sh 'chmod +x gradlew'
                    sh './gradlew clean build -x test'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    // [경로 핵심]
                    // -f cicd/Dockerfile: 루트 디렉토리의 cicd 폴더 안의 파일을 읽음
                    // ./backend: 빌드에 필요한 소스(JAR 파일 등)는 backend 폴더 안에 있음
                    sh "docker build -t ${DOCKER_IMAGE}:${env.BUILD_NUMBER} -f cicd/Dockerfile ./backend"

                    // Docker Hub 푸시
                    sh "docker push ${DOCKER_IMAGE}:${env.BUILD_NUMBER}"
                }
            }
        }

        stage('K8S Deploy') {
            steps {
                // K8S 설정 파일들이 루트/cicd/k8s에 있는 경우
                sh "kubectl apply -f cicd/k8s/ -n ${NAMESPACE}"

                // Deployment 이미지 업데이트
                sh "kubectl set image deployment/backend backend=${DOCKER_IMAGE}:${env.BUILD_NUMBER} -n ${NAMESPACE}"
            }
        }
    }

    post {
        success {
            echo '백엔드 배포 성공!'
        }
        failure {
            echo '백엔드 배포 실패. 로그를 확인하세요.'
        }
    }
}