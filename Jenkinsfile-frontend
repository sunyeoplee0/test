pipeline {
    agent any

    // 젠킨스 Global Tool Configuration에서 설정한 이름과 일치해야 함
    tools {
        nodejs 'node20'
    }

    environment {
        DOCKER_IMAGE = "sunyeoplee/frontend-app"
        NAMESPACE = "lee"
    }

    stages {
        stage('Checkout') {
            steps {
                // GitHub에서 최신 코드를 가져옴
                checkout scm
            }
        }

        stage('Frontend Build') {
            steps {
                // 소스코드가 있는 vue-project 폴더로 들어가서 빌드
                dir('vue-project') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                script {
                    // [핵심 수정] Dockerfile의 실제 위치인 vue-project/cicd/Dockerfile을 지정
                    // 빌드 컨텍스트(소스 위치)는 여전히 ./vue-project
                    sh "docker build -t ${DOCKER_IMAGE}:${env.BUILD_NUMBER} -f vue-project/cicd/Dockerfile ./vue-project"
                    sh "docker build -t ${DOCKER_IMAGE}:latest -f vue-project/cicd/Dockerfile ./vue-project"

                    // Docker Hub 로그인 상태여야 함 (서버에서 docker login 완료 필수)
                    sh "docker push ${DOCKER_IMAGE}:${env.BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('K8S Deploy') {
            steps {
                // K8S 설정파일이 루트의 cicd/k8s에 있다면 그대로 두고,
                // 만약 이것도 vue-project 폴더 안에 있다면 경로를 수정해야 합니다.
                sh "kubectl apply -f cicd/k8s/ -n ${NAMESPACE}"

                // Deployment의 이미지를 방금 빌드한 따끈따끈한 새 버전으로 교체
                sh "kubectl set image deployment/frontend frontend=${DOCKER_IMAGE}:${env.BUILD_NUMBER} -n ${NAMESPACE}"
            }
        }
    }

    post {
        success {
            echo '프론트엔드 배포 성공!'
        }
        failure {
            echo '배포 실패. 로그를 확인하세요.'
        }
    }
}