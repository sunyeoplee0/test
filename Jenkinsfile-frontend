pipeline {
    agent any

    // 이 블록이 추가되어야 대시보드에서 설정한 node20을 불러옵니다.
    tools {
        nodejs 'node20'
    }

    environment {
        DOCKER_IMAGE = "sunyeoplee/frontend-app"
        NAMESPACE = "lee"
        // PATH 설정은 tools가 알아서 해주므로 삭제해도 무방합니다.
    }

    stages {
        stage('Frontend Build') {
            steps {
                dir('vue-project') {
                    sh 'npm install'
                    sh 'npm run build'
                }
            }
        }

        stage('Docker Build & Push') {
            steps {
                // cicd 폴더 내의 Dockerfile을 사용하여 이미지 빌드
                // 빌드 컨텍스트는 vue-project 폴더로 지정
                script {
                    sh "docker build -t ${DOCKER_IMAGE}:${env.BUILD_NUMBER} -f cicd/Dockerfile ./vue-project"
                    sh "docker build -t ${DOCKER_IMAGE}:latest -f cicd/Dockerfile ./vue-project"

                    // Docker Hub 로그인 상태여야 함
                    sh "docker push ${DOCKER_IMAGE}:${env.BUILD_NUMBER}"
                    sh "docker push ${DOCKER_IMAGE}:latest"
                }
            }
        }

        stage('K8S Deploy') {
            steps {
                // k8s 폴더 내의 yaml 파일들을 적용 (경로 주의)
                sh "kubectl apply -f cicd/k8s/ -n ${NAMESPACE}"

                // 배포된 컨테이너의 이미지를 최신 버전으로 업데이트하여 롤링 업데이트 유도
                sh "kubectl set image deployment/frontend frontend=${DOCKER_IMAGE}:${env.BUILD_NUMBER} -n ${NAMESPACE}"
            }
        }
    }

    post {
        success {
            echo '배포가 성공적으로 완료되었습니다.'
        }
        failure {
            echo '배포 중 에러가 발생했습니다. 로그를 확인하세요.'
        }
    }
}